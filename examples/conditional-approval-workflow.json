{
  "name": "approval-workflow",
  "description": "AI generation with GitLab manual approval via pause mechanism",
  "steps": [
    {
      "id": "ai_initial",
      "type": "ai.generate",
      "config": {
        "provider": "gpt-4",
        "prompt": "Generate a brief summary of the code changes"
      }
    },
    {
      "id": "approval",
      "type": "slack.notify",
      "depends_on": ["ai_initial"],
      "pause": true,
      "config": {
        "webhook_url": "{{env.SLACK_WEBHOOK_URL}}",
        "channel": "#deployments",
        "message": "Review this AI-generated summary: {{steps.ai_initial.content}}",
        "gitlab_pipeline_url": "{{env.CI_SERVER_URL}}/{{env.CI_PROJECT_ID}}/-/pipelines/{{env.CI_PIPELINE_ID}}",
        "button_text": "Review in GitLab"
      }
    },
    {
      "id": "ai_final",
      "type": "ai.generate",
      "depends_on": ["approval"],
      "config": {
        "provider": "gpt-4",
        "prompt": "Generate a detailed response based on approval"
      }
    },
    {
      "id": "slack_notify",
      "type": "slack.notify",
      "depends_on": ["ai_final"],
      "config": {
        "webhook_url": "{{env.SLACK_WEBHOOK_URL}}",
        "channel": "#deployments",
        "message": "Approved! Final response: {{steps.ai_final.content}}"
      }
    }
  ]
}
