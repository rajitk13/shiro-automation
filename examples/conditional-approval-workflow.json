{
  "name": "ai-approval-workflow",
  "description": "AI generation with Slack approval and conditional execution",
  "steps": [
    {
      "id": "ai_initial",
      "type": "ai.generate",
      "config": {
        "model": "gpt-4",
        "prompt": "Generate a brief summary of the code changes"
      }
    },
    {
      "id": "approval",
      "type": "slack.approve",
      "depends_on": ["ai_initial"],
      "config": {
        "webhook_url": "{{env.SLACK_WEBHOOK_URL}}",
        "channel": "#deployments",
        "message": "Review this AI-generated summary: {{steps.ai_initial.output.text}}",
        "timeout": 43200,
        "poll_interval": 30,
        "blocking": false,
        "timeout_action": "continue"
      }
    },
    {
      "id": "ai_final",
      "type": "ai.generate",
      "depends_on": ["approval"],
      "condition": "{{steps.approval.status == 'approved'}}",
      "config": {
        "model": "gpt-4",
        "prompt": "Generate a detailed response based on approval"
      }
    },
    {
      "id": "slack_notify",
      "type": "slack.notify",
      "depends_on": ["ai_final"],
      "condition": "{{steps.approval.status == 'approved'}}",
      "config": {
        "webhook_url": "{{env.SLACK_WEBHOOK_URL}}",
        "channel": "#deployments",
        "message": "Approved! Final response: {{steps.ai_final.output.text}}"
      }
    }
  ]
}
