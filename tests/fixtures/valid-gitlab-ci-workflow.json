{
  "name": "gitlab-ci-workflow",
  "description": "Valid workflow for GitLab CI integration testing",
  "steps": [
    {
      "id": "get-diff",
      "type": "git.diff",
      "config": {
        "operation": "diff",
        "base": "{{env.CI_MERGE_REQUEST_DIFF_BASE_SHA}}",
        "target": "{{env.CI_COMMIT_SHA}}"
      }
    },
    {
      "id": "ai-review",
      "type": "ai.generate",
      "depends_on": ["get-diff"],
      "config": {
        "prompt": "Review this code diff:\n\n{{steps.get-diff.diff}}",
        "provider": "openai",
        "model": "gpt-4"
      }
    },
    {
      "id": "post-comment",
      "type": "gitlab",
      "depends_on": ["ai-review"],
      "config": {
        "operation": "post_comment",
        "body": "{{steps.ai-review.content}}"
      }
    }
  ]
}
