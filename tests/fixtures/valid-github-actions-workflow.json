{
  "name": "github-actions-workflow",
  "description": "Valid workflow for GitHub Actions integration testing",
  "steps": [
    {
      "id": "get-diff",
      "type": "git.diff",
      "config": {
        "operation": "diff",
        "base": "${{ github.event.pull_request.base.sha }}",
        "target": "${{ github.sha }}"
      }
    },
    {
      "id": "ai-review",
      "type": "ai.generate",
      "depends_on": ["get-diff"],
      "config": {
        "prompt": "Review this code diff:\n\n{{steps.get-diff.diff}}",
        "provider": "openai",
        "model": "gpt-4"
      }
    },
    {
      "id": "post-comment",
      "type": "github",
      "depends_on": ["ai-review"],
      "config": {
        "operation": "post_pr_comment",
        "body": "{{steps.ai-review.content}}"
      }
    }
  ]
}
